[Unit]
Description=ISA Gateway — Semantic Field Communication Server
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/zcs/projects/isa
ExecStart=/usr/bin/python3 /home/zcs/projects/isa/gateway.py --host 0.0.0.0 --port 8766
Restart=always
RestartSec=5
# 赫淮斯托斯安全加固(user模式可用)
PrivateTmp=yes
NoNewPrivileges=yes
MemoryMax=256M
StandardOutput=journal
StandardError=journal
SyslogIdentifier=isa-gateway

[Install]
WantedBy=default.target
